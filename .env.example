# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Supabase URL (Public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (Public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (PRIVATE - Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# POEDITOR API
# ============================================
# Get this from: https://poeditor.com/account/api

# POEditor API Token
NEXT_PUBLIC_POEDITOR_API_TOKEN=your-poeditor-api-token-here

# ============================================
# NEXT.JS CONFIGURATION
# ============================================
# Disable telemetry (optional)
NEXT_TELEMETRY_DISABLED=1

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Site URL (for production)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ============================================
# ORACLE DATABASE (Optional - for Database Connection feature)
# ============================================
# ORACLE_HOST=localhost
# ORACLE_PORT=1521
# ORACLE_SERVICE_NAME=ORCL
# ORACLE_USERNAME=your-username
# ORACLE_PASSWORD=your-password

# ============================================
# NOTES
# ============================================
# 1. Copy this file to .env.local for local development
# 2. Never commit .env.local to git
# 3. For production, set these in your deployment platform (Vercel, Netlify, etc.)
# 4. Keep SUPABASE_SERVICE_ROLE_KEY secret - never expose to client
